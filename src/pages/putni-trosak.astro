---
import BaseLayout from "../layouts/BaseLayout.astro";
import AccordionScript from "../components/AccordionScript.astro";
import content from "../static-pages/putni-trosak.html?raw";

const hasAccordion = content.includes("data-accordion");
---

<BaseLayout title="Caspera | Putni trošak" bodyClass="stranica-putni-trosak">
  <Fragment set:html={content} />
  {hasAccordion && <AccordionScript />}
</BaseLayout>
