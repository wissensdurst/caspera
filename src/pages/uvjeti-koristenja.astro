---
import BaseLayout from "../layouts/BaseLayout.astro";
import AccordionScript from "../components/AccordionScript.astro";
import content from "../static-pages/uvjeti-koristenja.html?raw";

const hasAccordion = content.includes("data-accordion");
---

<BaseLayout title="Caspera | Uvjeti korištenja" bodyClass="stranica-uvjeti-koristenja">
  <Fragment set:html={content} />
  {hasAccordion && <AccordionScript />}
</BaseLayout>
