---
import BaseLayout from "../layouts/BaseLayout.astro";
import AccordionScript from "../components/AccordionScript.astro";
import { injectBreadcrumbHtml } from "../lib/breadcrumbs";
import content from "../static-pages/izvjesce-o-radu.html?raw";

const hasAccordion = content.includes("data-accordion");
const processedContent = injectBreadcrumbHtml(content, [{ label: "Početna", href: "/" }, { label: "Izvješće o radu" }]);
---

<BaseLayout title="Caspera | Izvješće o radu" bodyClass="stranica-izvjesce-o-radu">
  <Fragment set:html={processedContent} />
  {hasAccordion && <AccordionScript />}
</BaseLayout>
