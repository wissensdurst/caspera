---
import BaseLayout from "../layouts/BaseLayout.astro";
import AccordionScript from "../components/AccordionScript.astro";
import { injectBreadcrumbHtml } from "../lib/breadcrumbs";
import content from "../static-pages/ortopedska-pomagala.html?raw";

const hasAccordion = content.includes("data-accordion");
const processedContent = injectBreadcrumbHtml(content, [{ label: "Početna", href: "/" }, { label: "Ortopedska pomagala" }]);
---

<BaseLayout title="Caspera | Ortopedska pomagala" bodyClass="stranica-ortopedska-pomagala">
  <Fragment set:html={processedContent} />
  {hasAccordion && <AccordionScript />}
</BaseLayout>
