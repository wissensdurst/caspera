---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PortableContent from "../../components/PortableContent.astro";
import { fetchSanity, formatDate, imageUrl, portableTextToPlainText, truncateText } from "../../lib/sanity";

export async function getStaticPaths() {
  const fetchedProjects = await fetchSanity(
    `*[_type == "project"] { "slug": slug.current }`,
    {},
    []
  );

  return fetchedProjects.map((project) => ({ params: { slug: project.slug } }));
}

const { slug } = Astro.params;
const project = await fetchSanity(
  `*[_type == "project" && slug.current == $slug][0] {
    title,
    "slug": slug.current,
    date,
    location,
    description,
    coverImage { asset->{url} },
    metaTitle,
    metaDescription,
    socialImage { asset->{url} },
    noIndex
  }`,
  { slug },
  null
);

if (!project) {
  return Astro.redirect("/nasi-projekti");
}

const seoDescription = truncateText(project.metaDescription || portableTextToPlainText(project.description));
const seoImage = imageUrl(project.socialImage || project.coverImage, { width: 1200, height: 630, fit: "crop" });
---

<BaseLayout
  title={project.metaTitle || `Caspera | ${project.title}`}
  description={seoDescription}
  canonicalUrl={`/nasi-projekti/${project.slug}`}
  ogTitle={project.metaTitle || project.title}
  ogDescription={seoDescription}
  ogImage={seoImage}
  noIndex={project.noIndex}
  bodyClass="stranica-nasi-projekti"
>
  <main class="calendar-page projects-page">
    <section class="project-detail story-detail">
      <nav class="story-detail__breadcrumbs" aria-label="Breadcrumb">
        <ol class="story-detail__breadcrumb-list">
          <li class="story-detail__breadcrumb-item"><a href="/">Početna</a></li>
          <li class="story-detail__breadcrumb-item"><a href="#">Caspera u akciji</a></li>
          <li class="story-detail__breadcrumb-item"><a href="/nasi-projekti">Naši projekti</a></li>
          <li class="story-detail__breadcrumb-item" aria-current="page">{project.title}</li>
        </ol>
      </nav>

      <article class="story-article project-article">
        <figure class="story-article__media">
          <img class="story-hero-image" src={imageUrl(project.coverImage)} alt={`Vizual projekta ${project.title}`} />
        </figure>

        <div class="story-content">
          <header class="story-content__header">
            <h1 class="story-title">{project.title}</h1>
            <div class="story-meta project-meta">
              <time class="story-meta__date" datetime={project.date}>{formatDate(project.date)}</time>
              <span class="project-meta__location">{project.location}</span>
            </div>
          </header>

          <div class="story-body">
            <PortableContent value={project.description} />
          </div>
        </div>
      </article>
    </section>
  </main>
</BaseLayout>
