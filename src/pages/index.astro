---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Caspera | Nova stranica uskoro"
  description="Nova web stranica udruge Caspera uskoro stiže. Za sva pitanja kontaktirajte nas e-poštom ili putem društvenih mreža."
  noIndex={true}
  bodyClass="stranica-uskoro"
  showNavbar={false}
  showFooter={false}
>
  <main class="maintenance-page">
    <section class="maintenance-page__panel" aria-labelledby="maintenance-title">
      <div class="maintenance-page__brand">
        <img class="maintenance-page__logo" src="/assets/images/logo_main.png" alt="Logo udruge Caspera" />
        <p class="maintenance-page__eyebrow">Podrška koja ostaje blizu</p>
      </div>

      <div class="maintenance-page__content">
        <h1 class="maintenance-page__title" id="maintenance-title">Nova web stranica uskoro stiže.</h1>
        <p class="maintenance-page__lead">
          Trenutno završavamo posljednje detalje kako bismo vam pružili bolje iskustvo korištenja.
        </p>
        <p class="maintenance-page__text">U međuvremenu nas možete kontaktirati putem:</p>
      </div>

      <ul class="maintenance-page__contacts" aria-label="Kontakt informacije">
        <li class="maintenance-page__contact">
          <span class="maintenance-page__contact-label">E-mail</span>
          <a class="maintenance-page__contact-link" href="mailto:info@caspera.hr">info@caspera.hr</a>
        </li>
        <li class="maintenance-page__contact">
          <span class="maintenance-page__contact-label">Facebook</span>
          <a
            class="maintenance-page__contact-link"
            href="https://www.facebook.com/Udruga-Caspera-104972824456568/"
            target="_blank"
            rel="noopener noreferrer"
          >
            Udruga Caspera
          </a>
        </li>
        <li class="maintenance-page__contact">
          <span class="maintenance-page__contact-label">Instagram</span>
          <a
            class="maintenance-page__contact-link"
            href="https://instagram.com/udrugacaspera?igshid=vqim766bhoye"
            target="_blank"
            rel="noopener noreferrer"
          >
            @udrugacaspera
          </a>
        </li>
      </ul>

      <p class="maintenance-page__closing">Hvala na razumijevanju i vidimo se uskoro!</p>
    </section>
  </main>
</BaseLayout>
