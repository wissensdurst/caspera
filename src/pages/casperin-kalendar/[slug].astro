---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import PortableContent from "../../components/PortableContent.astro";
import ShareActions from "../../components/ShareActions.astro";
import { fetchSanity, formatDate, imageUrl, imageUrlOrFallback, portableTextToPlainText, truncateText } from "../../lib/sanity";
import type { EventRecord, SlugRecord } from "../../lib/content-types";

export async function getStaticPaths() {
  const events = (await fetchSanity<SlugRecord[]>(`*[_type == "event" && defined(slug.current)] { "slug": slug.current }`)) ?? [];

  return events.map((event) => ({ params: { slug: event.slug } }));
}

const { slug } = Astro.params;
const event = await fetchSanity<EventRecord | null>(
  `*[_type == "event" && slug.current == $slug][0] {
    title,
    "slug": slug.current,
    dateTime,
    location,
    description,
    coverImage { asset->{url} },
    metaTitle,
    metaDescription,
    socialImage { asset->{url} },
    noIndex
  }`,
  { slug }
);

if (!event) {
  return Astro.redirect("/casperin-kalendar");
}

const seoDescription = truncateText(event.metaDescription || portableTextToPlainText(event.description));
const seoImage = imageUrl(event.socialImage || event.coverImage, { width: 1200, height: 630, fit: "crop" });
const shareUrl = new URL(`/casperin-kalendar/${event.slug}`, Astro.site ?? Astro.url).toString();
---

<BaseLayout
  title={event.metaTitle || `Caspera | ${event.title}`}
  description={seoDescription}
  canonicalUrl={`/casperin-kalendar/${event.slug}`}
  ogTitle={event.metaTitle || event.title}
  ogDescription={seoDescription}
  ogImage={seoImage}
  noIndex={event.noIndex}
  bodyClass="stranica-casperin-kalendar"
>
  <main class="calendar-page">
    <section class="event-detail story-detail">
      <Breadcrumbs items={[{ label: "Početna", href: "/" }, { label: "Casperin kalendar", href: "/casperin-kalendar" }, { label: event.title }]} />

      <article class="story-article event-article">
        <figure class="story-article__media">
          <img class="story-hero-image" src={imageUrlOrFallback(event.coverImage)} alt={`Vizual događaja ${event.title}`} />
        </figure>

        <div class="story-content">
          <header class="story-content__header">
            <h1 class="story-title">{event.title}</h1>
            <div class="story-meta event-meta">
              <time class="story-meta__date" datetime={event.dateTime}>{formatDate(event.dateTime)}</time>
              <span class="event-meta__location">{event.location}</span>
            </div>
          </header>

          <div class="story-body">
            <PortableContent value={event.description} />
          </div>

          <ShareActions title="Podijeli događaj" shareUrl={shareUrl} shareTitle={event.title} />
        </div>
      </article>
    </section>
  </main>
</BaseLayout>
