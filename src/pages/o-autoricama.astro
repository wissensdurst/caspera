---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { fetchSanity, imageUrl, portableTextToHtml } from "../lib/sanity";
import type { AuthorRecord } from "../lib/content-types";

const authors = await fetchSanity<AuthorRecord[]>(
  `*[_type == "author"] | order(displayOrder asc) {
    name,
    photo { asset->{url} },
    shortBio,
    displayOrder
  }`,
  {},
  []
);

const authorCards = authors.map((author: AuthorRecord) => {
  const photo = imageUrl(author.photo) || "/assets/images/placeholder.png";
  const bio = portableTextToHtml(author.shortBio);

  return {
    ...author,
    photo,
    bio,
  };
});
---

<BaseLayout title="Caspera | O autoricama" bodyClass="stranica-savjetodavatelji">
  <main>
    <section class="tim tim--centred-cards" aria-labelledby="naslov-popisa-autorica">
      <div class="tim__unutarnji">
        <Breadcrumbs items={[{ label: "Početna", href: "/" }, { label: "O autoricama" }]} />
        <header class="tim__uvod">
          <h1 class="tim__naslov" id="naslov-popisa-autorica">O autoricama</h1>
          <div class="tim__tekstovi">
            <p class="tim__tekst">
              Autorice koje dijele osobna iskustva, oporavak i trenutke podrške kroz Casperinu rubriku Moja priča.
            </p>
          </div>
        </header>

        <section class="tim__mreza" aria-label="Popis autorica">
          {
            authorCards.map((author) => (
              <button
                class="kartica-tima"
                type="button"
                data-team-card
                data-name={author.name}
                data-image={author.photo}
                data-image-alt={`Profilna fotografija autorice ${author.name}`}
                data-bio-html={author.bio}
                aria-label={`Otvori profil autorice ${author.name}`}
              >
                <div class="kartica-tima__slika-okvir">
                  <img class="kartica-tima__slika" src={author.photo} alt={`Profilna fotografija autorice ${author.name}`} />
                </div>
                <div class="kartica-tima__sadrzaj">
                  <h2 class="kartica-tima__ime">{author.name}</h2>
                </div>
              </button>
            ))
          }
        </section>
        {
          authorCards.length === 0 && (
            <p class="tim__tekst">Trenutno nema objavljenih autorica.</p>
          )
        }

        {authorCards.length > 0 && <div class="modal-clan-tima" data-team-modal hidden>
          <div class="modal-clan-tima__pozadina" data-team-modal-close></div>
          <section class="modal-clan-tima__prozor" role="dialog" aria-modal="true" aria-labelledby="modal-clan-tima-naslov">
            <button class="modal-clan-tima__zatvori" type="button" data-team-modal-close aria-label="Zatvori prozor">
              <span aria-hidden="true">&times;</span>
            </button>
            <div class="modal-clan-tima__raspored">
              <div class="modal-clan-tima__slika-okvir">
                <img class="modal-clan-tima__slika" data-team-modal-image src="/assets/images/placeholder.png" alt="Profilna fotografija autorice" />
              </div>
              <div class="modal-clan-tima__sadrzaj">
                <h2 class="modal-clan-tima__ime" id="modal-clan-tima-naslov" data-team-modal-name>Ime autorice</h2>
                <div class="modal-clan-tima__opis" data-team-modal-bio>
                  <p>Opis autorice.</p>
                </div>
              </div>
            </div>
          </section>
        </div>}
      </div>
    </section>
  </main>

  <script is:inline>
    const teamModal = document.querySelector("[data-team-modal]");

    if (teamModal) {
      const teamCards = [...document.querySelectorAll("[data-team-card]")];
      const modalName = teamModal.querySelector("[data-team-modal-name]");
      const modalBio = teamModal.querySelector("[data-team-modal-bio]");
      const modalImage = teamModal.querySelector("[data-team-modal-image]");
      const modalCloseControls = [...teamModal.querySelectorAll("[data-team-modal-close]")];
      const pageBody = document.body;
      let lastFocusedCard = null;
      const getFocusableElements = () =>
        [...teamModal.querySelectorAll('a[href], button:not([disabled]), textarea, input, select, [tabindex]:not([tabindex="-1"])')].filter(
          (element) => !element.hasAttribute("hidden") && element.getAttribute("aria-hidden") !== "true"
        );

      const closeTeamModal = () => {
        teamModal.hidden = true;
        pageBody.classList.remove("modal-open");
        lastFocusedCard?.focus();
      };

      const openTeamModal = (card) => {
        lastFocusedCard = card;
        modalName.textContent = card.dataset.name ?? "";
        modalBio.innerHTML = card.dataset.bioHtml || card.dataset.bio || "";
        modalImage.src = card.dataset.image ?? modalImage.src;
        modalImage.alt = card.dataset.imageAlt ?? "";
        teamModal.hidden = false;
        pageBody.classList.add("modal-open");
        teamModal.querySelector("[data-team-modal-close]")?.focus();
      };

      teamCards.forEach((card) => {
        card.addEventListener("click", () => openTeamModal(card));
      });

      modalCloseControls.forEach((control) => {
        control.addEventListener("click", closeTeamModal);
      });

      document.addEventListener("keydown", (event) => {
        if (!teamModal.hidden && event.key === "Tab") {
          const focusableElements = getFocusableElements();
          const firstElement = focusableElements[0];
          const lastElement = focusableElements[focusableElements.length - 1];

          if (!firstElement || !lastElement) {
            event.preventDefault();
          } else if (event.shiftKey && document.activeElement === firstElement) {
            event.preventDefault();
            lastElement.focus();
          } else if (!event.shiftKey && document.activeElement === lastElement) {
            event.preventDefault();
            firstElement.focus();
          }
        }

        if (event.key === "Escape" && !teamModal.hidden) {
          closeTeamModal();
        }
      });
    }
  </script>
</BaseLayout>
