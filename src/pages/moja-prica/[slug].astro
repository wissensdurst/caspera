---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import PortableContent from "../../components/PortableContent.astro";
import ShareActions from "../../components/ShareActions.astro";
import { fetchSanity, formatDate, imageUrl, imageUrlOrFallback, portableTextToPlainText, truncateText } from "../../lib/sanity";
import type { AuthorRecord, SlugRecord, StoryRecord } from "../../lib/content-types";

export async function getStaticPaths() {
  const stories = (await fetchSanity<SlugRecord[]>(`*[_type == "story" && defined(slug.current)] { "slug": slug.current }`)) ?? [];

  return stories.map((story) => ({ params: { slug: story.slug } }));
}

const { slug } = Astro.params;
const story = await fetchSanity<StoryRecord | null>(
  `*[_type == "story" && slug.current == $slug][0] {
    title,
    "slug": slug.current,
    "author": select(
      defined(author._ref) => author->{ name, photo { asset->{url} }, shortBio, displayOrder },
      defined(author) => { "name": author, "photo": authorPhoto { asset->{url} }, "shortBio": "" }
    ),
    date,
    content,
    coverImage { asset->{url} },
    metaTitle,
    metaDescription,
    socialImage { asset->{url} },
    noIndex
  }`,
  { slug }
);

if (!story) {
  return Astro.redirect("/moja-prica");
}

const authorKey = (name = "") =>
  name
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");

const author: AuthorRecord | { name: string } | undefined =
  typeof story.author === "string" ? { name: story.author } : story.author;
const authorName = author?.name ?? "Autorica";
const authorPhotoSource = author && "photo" in author ? author.photo : undefined;
const authorPhoto = imageUrlOrFallback(authorPhotoSource);
const authorStoriesHref = `/moja-prica?author=${encodeURIComponent(authorKey(authorName))}`;
const seoDescription = truncateText(story.metaDescription || portableTextToPlainText(story.content));
const seoImage = imageUrl(story.socialImage || story.coverImage, { width: 1200, height: 630, fit: "crop" });
const shareUrl = new URL(`/moja-prica/${story.slug}`, Astro.site ?? Astro.url).toString();
---

<BaseLayout
  title={story.metaTitle || `Caspera | ${story.title}`}
  description={seoDescription}
  canonicalUrl={`/moja-prica/${story.slug}`}
  ogTitle={story.metaTitle || story.title}
  ogDescription={seoDescription}
  ogImage={seoImage}
  noIndex={story.noIndex}
  bodyClass="stranica-pojedina-prica"
>
  <main class="story-detail">
    <Breadcrumbs items={[{ label: "Početna", href: "/" }, { label: "Moja priča", href: "/moja-prica" }, { label: story.title }]} />

    <article class="story-article">
      <figure class="story-article__media">
        <img class="story-hero-image" src={imageUrlOrFallback(story.coverImage, authorPhoto)} alt={`Naslovna fotografija priče ${story.title}`} />
      </figure>

      <div class="story-content">
        <header class="story-content__header">
          <h1 class="story-title">{story.title}</h1>
          <div class="story-meta">
            <a class="story-meta__author" href={authorStoriesHref} aria-label={`Prikaži sve priče autorice ${authorName}`}>
              <span class="story-meta__avatar" aria-hidden="true">
                <img src={authorPhoto} alt="" />
              </span>
              <span>{authorName}</span>
            </a>
            <time class="story-meta__date" datetime={story.date}>{formatDate(story.date)}</time>
          </div>
        </header>

        <div class="story-body">
          <PortableContent value={story.content} />
        </div>

        <ShareActions title="Podijeli priču" shareUrl={shareUrl} shareTitle={story.title} />
      </div>
    </article>
  </main>
</BaseLayout>
