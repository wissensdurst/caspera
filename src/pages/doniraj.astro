---
import BaseLayout from "../layouts/BaseLayout.astro";
import AccordionScript from "../components/AccordionScript.astro";
import content from "../static-pages/doniraj.html?raw";

const hasAccordion = content.includes("data-accordion");
---

<BaseLayout title="Caspera | Doniraj" bodyClass="stranica-doniraj">
  <Fragment set:html={content} />
  {hasAccordion && <AccordionScript />}
</BaseLayout>
