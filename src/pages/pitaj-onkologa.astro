---
import BaseLayout from "../layouts/BaseLayout.astro";
import AccordionScript from "../components/AccordionScript.astro";
import { injectBreadcrumbHtml } from "../lib/breadcrumbs";
import content from "../static-pages/pitaj-onkologa.html?raw";

const hasAccordion = content.includes("data-accordion");
const processedContent = injectBreadcrumbHtml(content, [{ label: "Početna", href: "/" }, { label: "Pitaj onkologa" }]);
---

<BaseLayout title="Caspera | Pitaj onkologa" bodyClass="stranica-pitaj-onkologa">
  <Fragment set:html={processedContent} />
  {hasAccordion && <AccordionScript />}
</BaseLayout>
