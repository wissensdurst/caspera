---
import BaseLayout from "../layouts/BaseLayout.astro";
import AccordionScript from "../components/AccordionScript.astro";
import content from "../static-pages/pitaj-nutricionista.html?raw";

const hasAccordion = content.includes("data-accordion");
---

<BaseLayout title="Caspera | Pitaj nutricionista" bodyClass="stranica-pitaj-nutricionista">
  <Fragment set:html={content} />
  {hasAccordion && <AccordionScript />}
</BaseLayout>
